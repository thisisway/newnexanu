generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Organizations ──────────────────────────────────────────────────────────

model Organization {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  domain      String?   @unique
  logoUrl     String?
  plan        String    @default("starter")
  status      OrgStatus @default(ACTIVE)
  settings    Json      @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users             OrganizationUser[]
  roles             Role[]
  auditLogs         AuditLog[]
  clients           Client[]
  productCategories ProductCategory[]
  products          Product[]
  plans             Plan[]
  addons            Addon[]
  orders            Order[]
  subscriptions     Subscription[]
  invoices          Invoice[]
  payments          Payment[]
  tickets           Ticket[]
  webhooks          Webhook[]
  apiKeys           ApiKey[]
  domains           Domain[]

  @@map("organizations")
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  CANCELLED

  @@map("org_status")
}

// ─── Users ────────────────────────────────────────────────────────────────

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  name             String
  passwordHash     String
  avatarUrl        String?
  phone            String?
  emailVerifiedAt  DateTime?
  twoFactorSecret  String?
  twoFactorEnabled Boolean    @default(false)
  status           UserStatus @default(ACTIVE)
  lastLoginAt      DateTime?
  lastLoginIp      String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  organizations    OrganizationUser[]
  sessions         Session[]
  auditLogs        AuditLog[]
  clientNotes      ClientNote[]
  assignedTickets  Ticket[]
  ticketMessages   TicketMessage[]

  @@map("users")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED

  @@map("user_status")
}

// ─── Sessions ─────────────────────────────────────────────────────────────

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  ip           String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ─── Organization Users (multi-tenant membership) ─────────────────────────

model OrganizationUser {
  id              String       @id @default(cuid())
  organizationId  String
  userId          String
  roleId          String?
  status          MemberStatus @default(ACTIVE)
  invitedByUserId String?
  joinedAt        DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role?        @relation(fields: [roleId], references: [id])

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_users")
}

enum MemberStatus {
  ACTIVE
  INVITED
  SUSPENDED

  @@map("member_status")
}

// ─── Roles & Permissions (RBAC) ───────────────────────────────────────────

model Role {
  id             String   @id @default(cuid())
  organizationId String?
  name           String
  slug           String
  description    String?
  isSystem       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization?      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions  RolePermission[]
  members      OrganizationUser[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("roles")
}

model Permission {
  id          String @id @default(cuid())
  action      String @unique
  description String?
  module      String

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ─── Audit Logs ───────────────────────────────────────────────────────────

model AuditLog {
  id             String        @id @default(cuid())
  organizationId String?
  userId         String?
  action         String
  entity         String?
  entityId       String?
  before         Json?
  after          Json?
  metadata       Json?
  ip             String?
  userAgent      String?
  severity       AuditSeverity @default(INFO)
  createdAt      DateTime      @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL

  @@map("audit_severity")
}

// ─── Clients ──────────────────────────────────────────────────────────────

model Client {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  email          String
  document       String?
  documentType   DocumentType?
  phone          String?
  mobile         String?
  type           ClientType   @default(INDIVIDUAL)
  status         ClientStatus @default(ACTIVE)
  notes          String?
  address        Json?
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts       ClientContact[]
  clientNotes    ClientNote[]
  orders         Order[]
  subscriptions  Subscription[]
  invoices       Invoice[]
  payments       Payment[]
  tickets        Ticket[]
  ticketMessages TicketMessage[]
  domains        Domain[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([status])
  @@map("clients")
}

enum ClientType {
  INDIVIDUAL
  COMPANY

  @@map("client_type")
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  CANCELLED

  @@map("client_status")
}

enum DocumentType {
  CPF
  CNPJ
  OTHER

  @@map("document_type")
}

model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  email     String?
  phone     String?
  role      String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_contacts")
}

model ClientNote {
  id         String   @id @default(cuid())
  clientId   String
  userId     String
  content    String
  isInternal Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([clientId])
  @@map("client_notes")
}

// ─── Product Categories ───────────────────────────────────────────────────

model ProductCategory {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String
  description    String?
  icon           String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("product_categories")
}

// ─── Products ─────────────────────────────────────────────────────────────

model Product {
  id             String        @id @default(cuid())
  organizationId String
  categoryId     String?
  name           String
  slug           String
  description    String?
  type           ProductType   @default(SERVICE)
  status         ProductStatus @default(ACTIVE)
  features       Json?
  metadata       Json          @default("{}")
  sortOrder      Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     ProductCategory? @relation(fields: [categoryId], references: [id])
  plans        Plan[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([status])
  @@map("products")
}

enum ProductType {
  HOSTING
  VPS
  DOMAIN
  SSL
  EMAIL
  CLOUD_APP
  SERVICE
  OTHER

  @@map("product_type")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  HIDDEN

  @@map("product_status")
}

// ─── Plans ────────────────────────────────────────────────────────────────

model Plan {
  id             String     @id @default(cuid())
  organizationId String
  productId      String
  name           String
  slug           String
  description    String?
  status         PlanStatus @default(ACTIVE)
  features       Json?
  limits         Json?
  metadata       Json       @default("{}")
  sortOrder      Int        @default(0)
  isPopular      Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  prices       PlanPrice[]
  addons       Addon[]
  orders       Order[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([productId])
  @@map("plans")
}

enum PlanStatus {
  ACTIVE
  INACTIVE
  ARCHIVED

  @@map("plan_status")
}

model PlanPrice {
  id        String       @id @default(cuid())
  planId    String
  currency  String       @default("BRL")
  cycle     BillingCycle
  amount    Decimal      @db.Decimal(10, 2)
  setupFee  Decimal      @default(0) @db.Decimal(10, 2)
  trialDays Int          @default(0)
  isDefault Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  plan   Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([planId, currency, cycle])
  @@index([planId])
  @@map("plan_prices")
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
  BIANNUAL
  ONE_TIME

  @@map("billing_cycle")
}

// ─── Addons ───────────────────────────────────────────────────────────────

model Addon {
  id             String      @id @default(cuid())
  organizationId String
  planId         String?
  name           String
  description    String?
  type           AddonType   @default(ONE_TIME)
  price          Decimal     @db.Decimal(10, 2)
  setupFee       Decimal     @default(0) @db.Decimal(10, 2)
  status         AddonStatus @default(ACTIVE)
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan?        @relation(fields: [planId], references: [id])
  orderAddons  OrderAddon[]

  @@index([organizationId])
  @@index([planId])
  @@map("addons")
}

enum AddonType {
  ONE_TIME
  RECURRING

  @@map("addon_type")
}

enum AddonStatus {
  ACTIVE
  INACTIVE

  @@map("addon_status")
}

// ─── Orders ───────────────────────────────────────────────────────────────

model Order {
  id             String      @id @default(cuid())
  organizationId String
  clientId       String
  planId         String
  planPriceId    String
  status         OrderStatus @default(PENDING)
  billingCycle   BillingCycle
  quantity       Int         @default(1)
  unitPrice      Decimal     @db.Decimal(10, 2)
  setupFee       Decimal     @default(0) @db.Decimal(10, 2)
  discount       Decimal     @default(0) @db.Decimal(10, 2)
  total          Decimal     @db.Decimal(10, 2)
  notes          String?
  metadata       Json        @default("{}")
  activatedAt    DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id])
  plan         Plan         @relation(fields: [planId], references: [id])
  planPrice    PlanPrice    @relation(fields: [planPriceId], references: [id])
  subscription Subscription?
  invoices     Invoice[]
  orderAddons  OrderAddon[]

  @@index([organizationId])
  @@index([clientId])
  @@index([status])
  @@map("orders")
}

model OrderAddon {
  id       String  @id @default(cuid())
  orderId  String
  addonId  String
  quantity Int     @default(1)
  price    Decimal @db.Decimal(10, 2)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  addon Addon @relation(fields: [addonId], references: [id])

  @@index([orderId])
  @@map("order_addons")
}

enum OrderStatus {
  PENDING
  ACTIVE
  SUSPENDED
  CANCELLED
  FRAUD

  @@map("order_status")
}

// ─── Subscriptions ────────────────────────────────────────────────────────

model Subscription {
  id               String             @id @default(cuid())
  organizationId   String
  orderId          String             @unique
  clientId         String
  status           SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  nextBillingDate    DateTime
  cancelAtPeriodEnd  Boolean          @default(false)
  cancelledAt        DateTime?
  trialEndsAt        DateTime?
  metadata           Json             @default("{}")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order        Order        @relation(fields: [orderId], references: [id])
  client       Client       @relation(fields: [clientId], references: [id])
  invoices     Invoice[]

  @@index([organizationId])
  @@index([clientId])
  @@index([status])
  @@index([nextBillingDate])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
  EXPIRED

  @@map("subscription_status")
}

// ─── Invoices ─────────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  clientId       String
  orderId        String?
  subscriptionId String?
  number         String
  status         InvoiceStatus @default(DRAFT)
  currency       String        @default("BRL")
  subtotal       Decimal       @db.Decimal(10, 2)
  discount       Decimal       @default(0) @db.Decimal(10, 2)
  tax            Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  dueDate        DateTime
  paidAt         DateTime?
  notes          String?
  metadata       Json          @default("{}")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client        @relation(fields: [clientId], references: [id])
  order        Order?        @relation(fields: [orderId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  items        InvoiceItem[]
  payments     Payment[]

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)
  discount    Decimal @default(0) @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  OVERDUE
  CANCELLED
  REFUNDED

  @@map("invoice_status")
}

// ─── Payments ─────────────────────────────────────────────────────────────

model Payment {
  id             String        @id @default(cuid())
  organizationId String
  invoiceId      String
  clientId       String
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("BRL")
  gatewayId      String?
  gatewayData    Json?
  pixCode        String?
  pixExpiry      DateTime?
  boletoCode     String?
  boletoUrl      String?
  boletoExpiry   DateTime?
  paidAt         DateTime?
  failedAt       DateTime?
  failReason     String?
  metadata       Json          @default("{}")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Invoice      @relation(fields: [invoiceId], references: [id])
  client       Client       @relation(fields: [clientId], references: [id])

  @@index([organizationId])
  @@index([invoiceId])
  @@index([status])
  @@map("payments")
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  BOLETO
  BANK_TRANSFER
  BALANCE

  @@map("payment_method")
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
  REFUNDED
  CHARGEBACK

  @@map("payment_status")
}

// ─── Tickets / Support ────────────────────────────────────────────────────

model Ticket {
  id             String         @id @default(cuid())
  organizationId String
  clientId       String?
  assignedToId   String?
  number         Int
  subject        String
  status         TicketStatus   @default(OPEN)
  priority       TicketPriority @default(MEDIUM)
  category       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  closedAt       DateTime?

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?         @relation(fields: [clientId], references: [id])
  assignedTo   User?           @relation(fields: [assignedToId], references: [id])
  messages     TicketMessage[]

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([clientId])
  @@index([status])
  @@map("tickets")
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  userId     String?
  clientId   String?
  body       String   @db.Text
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  ticket Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])

  @@index([ticketId])
  @@map("ticket_messages")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CLIENT
  RESOLVED
  CLOSED

  @@map("ticket_status")
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@map("ticket_priority")
}

// ─── Webhooks ─────────────────────────────────────────────────────────────

model Webhook {
  id              String        @id @default(cuid())
  organizationId  String
  name            String
  url             String
  secret          String?
  events          String[]
  status          WebhookStatus @default(ACTIVE)
  lastTriggeredAt DateTime?
  failCount       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries   WebhookDelivery[]

  @@index([organizationId])
  @@map("webhooks")
}

model WebhookDelivery {
  id         String   @id @default(cuid())
  webhookId  String
  event      String
  payload    Json
  statusCode Int?
  response   String?
  success    Boolean  @default(false)
  createdAt  DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@map("webhook_deliveries")
}

enum WebhookStatus {
  ACTIVE
  INACTIVE

  @@map("webhook_status")
}

// ─── API Keys ─────────────────────────────────────────────────────────────

model ApiKey {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  keyPrefix      String
  keyHash        String
  scopes         String[]
  status         ApiKeyStatus @default(ACTIVE)
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([keyHash])
  @@map("api_keys")
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED

  @@map("api_key_status")
}

// ─── Domains ──────────────────────────────────────────────────────────────

model Domain {
  id             String       @id @default(cuid())
  organizationId String
  clientId       String?
  name           String
  status         DomainStatus @default(ACTIVE)
  registrar      String?
  expiresAt      DateTime?
  autoRenew      Boolean      @default(true)
  notes          String?
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?      @relation(fields: [clientId], references: [id])

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([clientId])
  @@map("domains")
}

enum DomainStatus {
  ACTIVE
  EXPIRED
  EXPIRING_SOON
  PENDING_TRANSFER
  SUSPENDED

  @@map("domain_status")
}
